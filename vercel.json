{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.py": {
      "maxDuration": 60,
      "includeFiles": "{api/models/**,public/data/dashboard-history.json}",
      "excludeFiles": "{public/legacy/**,archive/**,source-data/**,tests/**,**/__pycache__/**,**/.pytest_cache/**,**/*.pyc}"
    }
  }
}
