{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    }
  ],
  "functions": {
    "api/index.py": {
      "maxDuration": 60,
      "includeFiles": "public/data/dashboard-history.json",
      "excludeFiles": "{public/legacy/**,archive/**,source-data/**,tests/**,**/__pycache__/**,**/.pytest_cache/**,**/*.pyc,**/site-packages/**/tests/**,**/site-packages/**/test/**,**/site-packages/**/testing/**,**/site-packages/**/*.pyi}"
    }
  }
}
